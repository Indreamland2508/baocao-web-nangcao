@model List<BAOCAOWEBNANGCAO.Models.CartItem>

@{
    ViewData["Title"] = "Thanh toán";
    decimal cartTotal = Model?.Sum(item => item.TotalPrice) ?? 0;
}

<div class="container py-5">

    <form asp-action="Checkout" asp-controller="Cart" method="post">

        @Html.AntiForgeryToken()

        <div class="row g-4">

            <!-- LEFT SIDE -->
            <div class="col-lg-7">

                <div class="card p-4">

                    <h4 class="fw-bold mb-4">Thông tin nhận hàng</h4>

                    <div class="mb-3">
                        <label>Email</label>
                        <input type="email" name="customerEmail" class="form-control">
                    </div>

                    <div class="mb-3">
                        <label>Họ và tên</label>
                        <input type="text" name="customerName" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label>Số điện thoại</label>
                        <input type="text" name="customerPhone" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label>Địa chỉ giao hàng</label>
                        <input type="text" name="shippingAddress" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label>Ghi chú</label>
<textarea name="note" class="form-control"></textarea>
                    </div>

                    <h5 class="fw-bold mt-4">Thời gian thuê</h5>

                    <div class="row">

                        <div class="col-md-6">
                            <label>Từ ngày</label>
                            <input type="date"
                                   name="rentalStart"
                                   id="rentalStart"
                                   class="form-control"
                                   required
                                   value="@DateTime.Now.ToString("yyyy-MM-dd")">
                        </div>

                        <div class="col-md-6">
                            <label>Đến ngày</label>
                            <input type="date"
                                   name="rentalEnd"
                                   id="rentalEnd"
                                   class="form-control"
                                   required
                                   value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")">
                        </div>

                    </div>

                    <p class="mt-2">
                        Số ngày thuê: <b id="dayCount">1</b>
                    </p>

                </div>
            </div>

            <!-- RIGHT SIDE -->
            <div class="col-lg-5">

                <div class="card p-4">

                    <h5 class="fw-bold mb-3">Đơn hàng (@Model.Count)</h5>

                    @foreach (var item in Model)
                    {
                        <div class="d-flex justify-content-between mb-2">

                            <div>
                                <b>@item.Product.Name</b>
                                <br>
                                <small>x @item.Quantity</small>
                            </div>

                            <div>
                                @item.TotalPrice.ToString("#,##0") ₫
                            </div>

                        </div>
                    }

                    <hr>

                    <div class="d-flex justify-content-between">
                        <span>Tạm tính</span>
                        <b>@cartTotal.ToString("#,##0") ₫</b>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span>Số ngày</span>
                        <b id="dayCountReview">1</b>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between">

                        <span class="fw-bold">Tổng cộng</span>

                        <span class="fw-bold text-success" id="finalTotal">
                            @cartTotal.ToString("#,##0") ₫
                        </span>

                    </div>

                    <button type="submit" class="btn btn-success w-100 mt-3">
                        Xác nhận đặt hàng
                    </button>

                </div>

            </div>

        </div>

    </form>

</div>

<script>

    document.addEventListener("DOMContentLoaded",function(){

    const startInput = document.getElementById("rentalStart");
    const endInput = document.getElementById("rentalEnd");

    const dayCount = document.getElementById("dayCount");
    const dayCountReview = document.getElementById("dayCountReview");
    const finalTotal = document.getElementById("finalTotal");

    const basePrice = @cartTotal.ToString(System.Globalization.CultureInfo.InvariantCulture);

    function updatePrice(){

    const start = new Date(startInput.value);
    const end = new Date(endInput.value);

    let days = Math.ceil((end-start)/(1000*60*60*24));

    if(days <= 0) days = 1;

    dayCount.innerText = days;
    dayCountReview.innerText = days;

    let total = basePrice * days;

    finalTotal.innerText = total.toLocaleString('vi-VN') + " ₫";

    }

    startInput.addEventListener("change",updatePrice);
    endInput.addEventListener("change",updatePrice);

    });

</script>