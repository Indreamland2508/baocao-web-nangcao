@using Microsoft.AspNetCore.Identity
@model IdentityUser

@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-3">
    <div class="row mb-4">
        <div class="col-12">
            <h3 class="fw-bold text-secondary"><i class="bi bi-person-vcard me-2"></i>Hồ Sơ Của Tôi</h3>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-xl-4 col-lg-5 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center py-5">
                    <img src="https://ui-avatars.com/api/?name=@Model.UserName&background=0d6efd&color=fff&size=150&font-size=0.33"
                         class="rounded-circle shadow mb-4" alt="Avatar" style="border: 5px solid #f8f9fa;">

                    <h4 class="fw-bold text-dark mb-1">@Model.UserName</h4>

                    <div class="mt-3 mb-4">
                        <span class="badge bg-primary px-3 py-2 rounded-pill fs-6 shadow-sm">
                            <i class="bi bi-shield-check me-1"></i> @ViewBag.RoleName
                        </span>
                    </div>

                    <hr class="text-muted my-4">

                    <div class="d-grid gap-2 px-4">
                        <button class="btn btn-outline-secondary">
                            <i class="bi bi-key me-2"></i> Đổi mật khẩu
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-8 col-lg-7 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h5 class="m-0 fw-bold text-primary"><i class="bi bi-pencil-square me-2"></i>Chi tiết tài khoản</h5>
                </div>
                <div class="card-body px-4">
                    <form asp-action="UpdateProfile" method="post">
                        <div class="row mb-4">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label class="form-label text-muted fw-bold small text-uppercase">Email đăng nhập</label>
                                <input type="email" class="form-control bg-light" value="@Model.Email" readonly>
                                <div class="form-text"><i class="bi bi-info-circle"></i> Không thể thay đổi Email đăng nhập.</div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted fw-bold small text-uppercase">Số điện thoại</label>
                                <input type="text" name="phoneNumber" class="form-control" value="@Model.PhoneNumber" placeholder="Nhập số điện thoại...">
                            </div>
                        </div>

                        <div class="row mb-5">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label class="form-label text-muted fw-bold small text-uppercase mb-2">Trạng thái xác thực</label>
                                <div>
                                    @if (Model.EmailConfirmed)
                                    {
                                        <span class="text-success fw-bold"><i class="bi bi-check-circle-fill me-1"></i> Đã kích hoạt</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning fw-bold"><i class="bi bi-exclamation-circle-fill me-1"></i> Chưa kích hoạt</span>
                                    }
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted fw-bold small text-uppercase">ID Hệ thống</label>
                                <input type="text" class="form-control bg-light text-muted" value="@Model.Id" readonly style="font-size: 0.85rem;">
                            </div>
                        </div>

                        <hr class="text-muted mb-4">

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary px-4 py-2 fw-bold">
                                <i class="bi bi-floppy me-2"></i> Lưu Thay Đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>