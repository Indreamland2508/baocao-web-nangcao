<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="~/icon.jpg" />
    <style>
        body {
            background-color: #f4f8f5; /* Nền xám xanh nhạt dịu mắt */
            padding-top: 70px;
            font-family: 'Plus Jakarta Sans', sans-serif; /* Font chữ tròn trịa hiện đại */
        }

        /* --- HEADER KÍNH MỜ (GLASSMORPHISM) --- */
        .admin-header {
            height: 70px;
            background-color: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px); /* Hiệu ứng mờ ảo đằng sau */
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
            position: fixed;
            top: 0;
            right: 0;
            left: 260px;
            z-index: 1030;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 0 30px;
            border-bottom: 1px solid rgba(255,255,255,0.3);
        }

        /* --- SIDEBAR MÀU XANH RỪNG SÂU --- */
        .sidebar {
            width: 260px;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            /* Dải màu gradient từ xanh lục đậm xuống xanh rêu */
            background: linear-gradient(180deg, #1a3a28 0%, #2e5a40 100%);
            z-index: 1040;
            overflow-y: auto;
            box-shadow: 4px 0 20px rgba(0,0,0,0.05);
        }

        .sidebar-brand {
            padding: 25px 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 20px;
        }

        .sidebar a {
            color: #a3c9b3;
            text-decoration: none;
            padding: 12px 20px;
            margin: 5px 20px; /* Thụt vào một chút để bo tròn góc */
            border-radius: 12px; /* Bo góc mềm mại */
            display: flex;
            align-items: center;
            transition: all 0.3s ease;
            font-weight: 500;
        }

            .sidebar a i {
                margin-right: 12px;
                font-size: 1.1rem;
            }
            /* Hiệu ứng khi di chuột hoặc đang ở trang đó */
            .sidebar a:hover, .sidebar a.active {
                background-color: rgba(255,255,255,0.15);
                color: #ffffff;
                transform: translateX(5px); /* Trượt nhẹ sang phải */
            }

        /* --- NỘI DUNG CHÍNH --- */
        .content {
            margin-left: 260px;
            padding: 30px;
        }

        /* Ép chuẩn cho tất cả các thẻ Card trong Admin */
        .card {
            border-radius: 20px !important;
            border: none !important;
            box-shadow: 0 10px 30px rgba(0,0,0,0.04) !important;
        }
        /* Ép chuẩn nút bấm bo tròn */
        .btn {
            border-radius: 50rem !important; /* Pill-shape */
        }

        .table {
            border-radius: 15px;
            overflow: hidden;
        }
    </style>
</head>
<body>
    @{
        string currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        string currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    }

    <div class="sidebar">
        <div class="sidebar-brand">
            <h5 class="text-white fw-bold m-0 tracking-wide">
                <i class="bi bi-tent text-success"></i> CAMPING ADMIN
            </h5>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Admin" asp-action="Index"
               class="@(currentController == "Admin" ? "active" : "")">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <a asp-controller="Categories" asp-action="Index"
               class="@(currentController == "Categories" ? "active" : "")">
                <i class="bi bi-tags"></i> Danh mục
            </a>

            <a asp-controller="Products" asp-action="Index"
               class="@(currentController == "Products" ? "active" : "")">
                <i class="bi bi-box-seam"></i> Quản lý Lều
            </a>
            <a asp-controller="Accounts" asp-action="Index"
               class="@(currentController == "Accounts" && currentAction == "Index" ? "active" : "")">
                <i class="bi bi-people"></i> Quản lý Tài khoản
            </a>
        }
        <div>
            

            <a asp-controller="Orders" asp-action="Index"
               class="@(currentController == "Orders" ? "active" : "")">
                <i class="bi bi-receipt"></i> Đơn thuê
            </a>
            <a asp-controller="Accounts" asp-action="MyProfile"
               class="@(currentAction == "MyProfile" ? "active" : "")">
                <i class="bi bi-person-vcard"></i> Hồ sơ của tôi
            </a>
        </div>
    </div>

    <header class="admin-header">
        <div class="d-flex align-items-center">
            <div class="pe-3 me-3 border-end">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="text-success text-decoration-none fw-bold small">
                    <i class="bi bi-shop"></i> Xem trang khách
                </a>
            </div>

            <span class="me-3 fw-medium text-dark">
                Xin chào, <span class="text-success">@User.Identity?.Name!</span>
            </span>

            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                <button type="submit" class="btn btn-danger btn-sm px-3 shadow-sm fw-bold">
                    <i class="bi bi-box-arrow-right me-1"></i> Thoát
                </button>
            </form>
        </div>
    </header>

    <div class="content">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>