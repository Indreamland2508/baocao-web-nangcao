@model IEnumerable<BAOCAOWEBNANGCAO.Models.Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
    Layout = "_AdminLayout";
}
@{
    var lowStock = Model.Where(p => p.Quantity <= 3 && p.Quantity > 0).ToList();
}

<style>
    /* Giữ phong cách bảng hiện đại */
    .table-modern thead th {
        background-color: #f8f9fa;
        color: #6c757d;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        border: none;
        padding: 1.25rem;
    }

    .table-modern tbody td {
        padding: 1.25rem;
        vertical-align: middle;
        border-bottom: 1px solid #f1f3f5;
    }

    .img-product {
        border-radius: 12px;
        object-fit: cover;
        box-shadow: 0 4px 8px rgba(0,0,0,0.05);
    }

    .search-box {
        border-radius: 50rem;
        padding-left: 1.5rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.03);
    }

    .btn-action {
        border-radius: 10px;
        width: 38px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
</style>

<div class="container-fluid px-4 mt-4">
    <div class="row align-items-center mb-4">
        <div class="col-md-5">
            <h2 class="fw-bold text-dark m-0">Danh sách sản phẩm</h2>
            <p class="text-muted small m-0">Quản lý kho hàng và giá thuê</p>
        </div>
        <div class="col-md-4">
            <form method="get" class="d-flex">
                <div class="input-group">
                    <input type="text" name="search" value="@ViewBag.Search"
                           class="form-control search-box border-0"
                           placeholder="Tìm sản phẩm theo tên..." />
                    <button class="btn btn-white text-primary border-0 ms-n5" type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>
        </div>
        <div class="col-md-3 text-end">
            <a asp-action="Create" class="btn btn-success px-4 py-2 fw-bold shadow-sm">
                <i class="bi bi-plus-lg me-2"></i>Thêm sản phẩm
            </a>
        </div>
    </div>

    @if (lowStock.Any())
    {
        <div class="alert alert-warning border-0 shadow-sm mb-4 d-flex align-items-center" style="border-radius: 15px;">
            <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
            <div>
                <strong class="d-block">⚠ Cảnh báo sắp hết hàng!</strong>
                @foreach (var item in lowStock)
                {
                    <span class="badge bg-danger rounded-pill me-1">
                        @item.Name (@item.Quantity còn lại)
                    </span>
                }
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm" style="border-radius: 20px;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-modern mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Ảnh</th>
                            <th>Tên</th>
                            <th>Mô tả</th>
                            <th>Giá / ngày</th>
                            <th>Trạng thái</th>
                            <th>Loại</th>
                            <th class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="@(item.Quantity == 0 ? "table-danger" : item.Quantity <= 3 ? "table-warning" : "")">
                                <td class="ps-4" style="width: 120px;">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" class="img-product"
                                             style="width: 80px; height: 60px;" alt="@item.Name" />
                                    }
                                    else
                                    {
                                        <div class="bg-light text-muted d-flex align-items-center justify-content-center img-product"
                                             style="width: 80px; height: 60px; font-size: 0.7rem;">
                                            No Image
                                        </div>
                                    }
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@item.Name</div>
                                </td>
                                <td class="text-muted small" style="max-width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    @item.Description
                                </td>
                                <td class="fw-bold text-success">
                                    @item.PricePerDay.ToString("#,##0") đ
                                </td>
                                <td>
                                    @if (item.Quantity == 0)
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-2 border border-danger border-opacity-25">Hết hàng</span>
                                    }
                                    else if (item.Quantity <= 3)
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3 py-2 border border-warning border-opacity-25 text-dark">Sắp hết</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 border border-success border-opacity-25">Còn hàng</span>
                                    }
                                </td>
                                <td>
                                    <span class="text-secondary small fw-medium">@item.Category?.Name</span>
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-light text-warning btn-action shadow-sm me-1" title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger rounded-pill px-3 delete-btn"
                                            data-id="@item.Id"
                                            data-name="@item.Name">
                                        <i class="bi bi-trash3"></i> Xóa
                                    </button>

                                    <form id="delete-form-@item.Id" asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:none;">
                                        @Html.AntiForgeryToken()
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white border-0 py-4 px-4" style="border-radius: 0 0 20px 20px;">
            <div class="row align-items-center">
                <div class="col-md-6 text-muted small">
                    Đang xem <strong>@(((ViewBag.CurrentPage - 1) * 5) + 1)</strong> -
                    <strong>@(Math.Min(ViewBag.CurrentPage * 5, ViewBag.TotalItems))</strong>
                    trong <strong>@ViewBag.TotalItems</strong> sản phẩm
                </div>
                <div class="col-md-6">
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-sm mb-0 justify-content-end">
                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "") mx-1">
                                    <a class="page-link border-0 rounded shadow-sm"
                                       href="?page=@i&search=@ViewBag.Search">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
        @section Scripts {
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

            <script>
                $(document).ready(function () {
                    // Sử dụng $(document).on để đảm bảo bắt được sự kiện kể cả khi bảng thay đổi dữ liệu
                    $(document).on('click', '.delete-btn', function (e) {
                        e.preventDefault(); // Ngăn chặn hành động mặc định

                        const id = $(this).data('id');
                        const name = $(this).data('name');

                        Swal.fire({
                            title: 'Xác nhận xóa?',
                            text: `Bạn có chắc chắn muốn xóa sản phẩm "${name}" không? Hành động này không thể hoàn tác!`,
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonColor: '#d33',
                            cancelButtonColor: '#6c757d',
                            confirmButtonText: 'Đúng, xóa nó!',
                            cancelButtonText: 'Hủy bỏ',
                            customClass: {
                                popup: 'rounded-4' // Bo góc cho hộp thoại đồng bộ với UI của Châu
                            }
                        }).then((result) => {
                            if (result.isConfirmed) {
                                // Submit form ẩn
                                $(`#delete-form-${id}`).submit();
                            }
                        });
                    });
                });
            </script>
        }
    </div>
</div>