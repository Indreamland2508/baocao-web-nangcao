@model BAOCAOWEBNANGCAO.Models.Product

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .edit-card {
        border-radius: 24px;
        border: none;
        box-shadow: 0 10px 40px rgba(0,0,0,0.05);
    }

    .form-label {
        font-weight: 600;
        color: #495057;
        font-size: 0.9rem;
    }

    .form-control, .form-select {
        border-radius: 12px;
        padding: 12px 15px;
        border: 1px solid #e9ecef;
        background-color: #f8f9fa;
    }

        .form-control:focus {
            background-color: #fff;
            border-color: #198754;
            box-shadow: 0 0 0 4px rgba(25, 135, 84, 0.1);
        }

    .img-preview-box {
        background: #f8f9fa;
        border-radius: 15px;
        padding: 15px;
        border: 1px dashed #dee2e6;
    }

    .btn-save {
        background: linear-gradient(135deg, #198754 0%, #157347 100%);
        border: none;
        border-radius: 50rem;
        padding: 12px 30px;
        font-weight: 700;
        transition: all 0.3s;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(25, 135, 84, 0.2);
        }
</style>

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h3 class="fw-bold text-dark m-0">✏ Chỉnh sửa thông tin</h3>
                    <p class="text-muted small">Sản phẩm: <span class="text-success fw-bold">@Model.Name</span></p>
                </div>
                <a asp-action="Index" class="btn btn-light rounded-pill px-4 border">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>
            </div>

            <div class="card edit-card">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" enctype="multipart/form-data" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4 small"></div>

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ImageUrl" /> <div class="row">
                            <div class="col-12 mb-4">
                                <label asp-for="Name" class="form-label">Tên sản phẩm</label>
                                <input asp-for="Name" class="form-control" placeholder="Nhập tên lều..." />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-4">
                                <label asp-for="Description" class="form-label">Mô tả sản phẩm</label>
                                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="PricePerDay" class="form-label">Giá thuê / ngày (VNĐ)</label>
                                <input asp-for="PricePerDay" class="form-control" />
                                <span asp-validation-for="PricePerDay" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="Quantity" class="form-label">Số lượng trong kho</label>
                                <input asp-for="Quantity" class="form-control" />
                                <span asp-validation-for="Quantity" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-4">
                                <label asp-for="CategoryId" class="form-label">Danh mục sản phẩm</label>
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                            </div>

                            <div asp-validation-summary="ModelOnly" class="text-danger mb-4 small"></div>

                            <input type="hidden" asp-for="Id" />
                            @* Quan trọng: Luôn giữ lại giá trị ImageUrl cũ *@
                            <input type="hidden" asp-for="ImageUrl" />

                            <div class="col-md-6 mb-4">
                                <label class="form-label d-block">Hình ảnh hiện tại</label>
                                <div class="img-preview-box text-center" style="min-width: 150px;">
                                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                    {
                                        <img src="@(Model.ImageUrl.StartsWith("/") ? Model.ImageUrl : "/" + Model.ImageUrl)"
                                             class="img-fluid"
                                             style="max-height:150px; border-radius: 10px; object-fit: cover;"
                                             id="currentImage" />
                                    }
                                    else
                                    {
                                        <div class="text-muted py-4 small">Chưa có ảnh</div>
                                    }
                                </div>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label class="form-label">Đổi hình ảnh mới</label>
                                <div class="p-3 border rounded-3 bg-light text-center" style="border-style: dashed !important;">
                                    <input type="file" name="imageFile" id="imageInput" class="form-control border-0 bg-transparent" accept="image/*" />
                                    <p class="text-muted small m-0 mt-2">Chọn file ảnh để thay đổi</p>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-4 pt-4 border-top">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4">Hủy bỏ</a>
                            <button type="submit" class="btn btn-success btn-save shadow">
                                <i class="bi bi-save2 me-2"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}