@model BAOCAOWEBNANGCAO.Models.Category
@{
    ViewData["Title"] = "Thêm danh mục";
    Layout = "_AdminLayout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0">🆕 Thêm danh mục</h3>
                <a asp-action="Index" class="btn btn-light btn-sm border rounded-pill px-3"> Quay lại</a>
            </div>
            <div class="card border-0 shadow-sm" style="border-radius: 24px;">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create">
                        <div class="mb-4">
                            <label class="form-label fw-bold">Tên danh mục</label>
                            <input asp-for="Name" class="form-control rounded-3 bg-light border-0 p-3" placeholder="VD: Lều 4 người..." />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Mô tả ngắn</label>
                            <textarea asp-for="Description" class="form-control rounded-3 bg-light border-0 p-3" rows="3"></textarea>
                        </div>
                        <button type="submit" class="btn btn-success w-100 py-3 fw-bold rounded-3 shadow">
                            <i class="bi bi-save me-2"></i>Lưu danh mục
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>